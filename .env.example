# Database Configuration
# For local development, you can leave these blank (uses file:local.db)
# For production (Vercel), set these to your Turso database credentials

# Turso Database URL (get from: https://turso.tech)
TURSO_DATABASE_URL=

# Turso Auth Token (get from: turso db tokens create <database-name>)
TURSO_AUTH_TOKEN=
